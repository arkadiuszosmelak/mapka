# Dart / Flutter
.dart_tool/
.packages
.pub-cache/
.pub/
build/
**/pubspec_overrides.yaml

# Generated code (regenerate with `melos gen` / `melos intl`)
**/*.g.dart
**/*.config.dart
**/*.module.dart
**/*.mocks.dart
**/*.gen.dart
**/generated/

# Secrets — NEVER commit (these live in GitHub Secrets / locally only)
**/*-firebase-adminsdk-*.json
**/serviceAccount*.json
**/*.jks
**/*.keystore
**/key.properties

# Runtime dart-define config (Mapbox pk token etc.) — keep only the example.
/modules/app/config/*.json
!/modules/app/config/example.json

# Coverage
coverage/
*.lcov

# IDE / OS
.idea/
.vscode/
*.iml
.DS_Store

# FVM
.fvm/
